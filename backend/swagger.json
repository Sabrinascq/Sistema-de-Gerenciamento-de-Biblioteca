{
  "openapi": "3.0.0",
  "info": {
    "title": "API - Sistema de Gerenciamento de Biblioteca",
    "description": "Documentação da API para o Projeto de Engenharia de Software",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Realiza o login no sistema",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@email.com" },
                  "senha": { "type": "string", "example": "1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login realizado com sucesso, retorna o Token JWT" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/livros": {
      "get": {
        "tags": ["Livros"],
        "summary": "Lista todos os livros",
        "responses": { "200": { "description": "Lista de livros retornada com sucesso" } }
      },
      "post": {
        "tags": ["Livros"],
        "summary": "Cadastra um novo livro",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titulo": { "type": "string" },
                  "autor": { "type": "string" },
                  "editora": { "type": "string" },
                  "ano_publicacao": { "type": "integer" },
                  "categoria": { "type": "string" },
                  "isbn": { "type": "string" },
                  "quantidade_total": { "type": "integer" },
                  "quantidade_disponivel": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Livro cadastrado com sucesso" } }
      }
    },
    "/livros/buscar": {
      "get": {
        "tags": ["Livros"],
        "summary": "Busca livros com filtros",
        "parameters": [
          { "in": "query", "name": "titulo", "schema": { "type": "string" } },
          { "in": "query", "name": "autor", "schema": { "type": "string" } },
          { "in": "query", "name": "categoria", "schema": { "type": "string" } },
          { "in": "query", "name": "isbn", "schema": { "type": "string" } },
          { "in": "query", "name": "status", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Resultados da busca retornados" } }
      }
    },
    "/livros/{id}": {
      "put": {
        "tags": ["Livros"],
        "summary": "Edita as informações de um livro existente",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "titulo": { "type": "string" },
                  "autor": { "type": "string" },
                  "quantidade_total": { "type": "integer" },
                  "quantidade_disponivel": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Livro atualizado com sucesso" } }
      },
      "delete": {
        "tags": ["Livros"],
        "summary": "Exclui um livro do sistema",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Livro excluído com sucesso" } }
      }
    },
    "/leitores": {
      "get": {
        "tags": ["Leitores"],
        "summary": "Lista todos os leitores",
        "responses": { "200": { "description": "Lista de leitores retornada" } }
      },
      "post": {
        "tags": ["Leitores"],
        "summary": "Cadastra um novo leitor",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string" },
                  "cpf_ra": { "type": "string" },
                  "email": { "type": "string" },
                  "telefone": { "type": "string" },
                  "endereco": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Leitor cadastrado com sucesso" } }
      }
    },
    "/leitores/buscar": {
      "get": {
        "tags": ["Leitores"],
        "summary": "Busca leitores por Nome ou CPF/RA",
        "parameters": [
          { "in": "query", "name": "nome", "schema": { "type": "string" } },
          { "in": "query", "name": "cpf_ra", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Resultados da busca retornados" } }
      }
    },
    "/leitores/{id}": {
      "put": {
        "tags": ["Leitores"],
        "summary": "Edita os dados de um leitor",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string" },
                  "telefone": { "type": "string" },
                  "endereco": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Leitor atualizado com sucesso" } }
      }
    },
    "/leitores/{id}/inativar": {
      "patch": {
        "tags": ["Leitores"],
        "summary": "Inativa um leitor no sistema",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Leitor inativado com sucesso" } }
      }
    },
    "/emprestimos": {
      "get": {
        "tags": ["Empréstimos"],
        "summary": "Lista todos os empréstimos",
        "responses": { "200": { "description": "Lista de empréstimos retornada" } }
      },
      "post": {
        "tags": ["Empréstimos"],
        "summary": "Registra um novo empréstimo (Pode conter múltiplos IDs de livros)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "leitorId": { "type": "integer" },
                  "livroIds": { "type": "array", "items": { "type": "integer" } },
                  "data_emprestimo": { "type": "string", "format": "date" },
                  "data_prevista_devolucao": { "type": "string", "format": "date" }
                }
              }
            }
          }
        },
        "responses": { 
          "201": { "description": "Empréstimo registrado com sucesso" }, 
          "400": { "description": "Livro indisponível ou leitor inativo" } 
        }
      }
    },
    "/emprestimos/buscar": {
      "get": {
        "tags": ["Empréstimos"],
        "summary": "Filtra empréstimos por status, leitor ou data",
        "parameters": [
          { "in": "query", "name": "status", "schema": { "type": "string" } },
          { "in": "query", "name": "nome_leitor", "schema": { "type": "string" } },
          { "in": "query", "name": "data_emprestimo", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": { "200": { "description": "Resultados filtrados" } }
      }
    },
    "/emprestimos/meus": {
      "get": {
        "tags": ["Empréstimos"],
        "summary": "Lista apenas os empréstimos do leitor logado",
        "responses": { "200": { "description": "Histórico pessoal de empréstimos" } }
      }
    },
    "/emprestimos/{id}/devolver": {
      "put": {
        "tags": ["Empréstimos"],
        "summary": "Registra a devolução de um empréstimo",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Devolução realizada com sucesso" } }
      }
    }
  }
}